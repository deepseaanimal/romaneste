[
  {
    "id": "g01",
    "scenario": "greetings",
    "ro": "Bună ziua.",
    "en": "Hello. (formal, lit. 'good day')",
    "ru": "Здравствуйте.",
    "note": "Default polite greeting. Use with strangers, shopkeepers, officials. Informal version: just 'Bună.'"
  },
  {
    "id": "g02",
    "scenario": "greetings",
    "ro": "Salut.",
    "en": "Hi. (casual)",
    "ru": "Привет.",
    "note": "Friends and peers only. Don't say this at customs."
  },
  {
    "id": "g03",
    "scenario": "greetings",
    "ro": "La revedere.",
    "en": "Goodbye.",
    "ru": "До свидания."
  },
  {
    "id": "g04",
    "scenario": "greetings",
    "ro": "Mulțumesc.",
    "en": "Thank you.",
    "ru": "Спасибо.",
    "note": "Add 'mult' for 'thanks a lot': 'Mulțumesc mult.'"
  },
  {
    "id": "g05",
    "scenario": "greetings",
    "ro": "Vă rog.",
    "en": "Please. / You're welcome.",
    "ru": "Пожалуйста.",
    "note": "Polite form. Informal is 'te rog'. Literally 'I ask you'."
  },
  {
    "id": "g06",
    "scenario": "greetings",
    "ro": "Cu plăcere.",
    "en": "You're welcome. (lit. 'with pleasure')",
    "ru": "Пожалуйста. / С удовольствием."
  },
  {
    "id": "g07",
    "scenario": "greetings",
    "ro": "Mă scuzați.",
    "en": "Excuse me. (formal)",
    "ru": "Извините.",
    "note": "Use to get attention or apologize. Informal: 'scuză-mă'."
  },
  {
    "id": "g08",
    "scenario": "greetings",
    "ro": "Îmi pare rău.",
    "en": "I'm sorry.",
    "ru": "Мне жаль. / Извините.",
    "note": "Lit. 'it seems bad to me'. Use for genuine apology, not just bumping someone."
  },
  {
    "id": "g09",
    "scenario": "greetings",
    "ro": "Da.",
    "en": "Yes.",
    "ru": "Да.",
    "note": "Slavic loan — same word as Russian 'да'."
  },
  {
    "id": "g10",
    "scenario": "greetings",
    "ro": "Nu.",
    "en": "No.",
    "ru": "Нет."
  },

  {
    "id": "l01",
    "scenario": "language",
    "ro": "Vorbiți engleză?",
    "en": "Do you speak English?",
    "ru": "Вы говорите по-английски?",
    "note": "Formal 'you'. 'Vorbiți' is the polite form of 'speak'."
  },
  {
    "id": "l02",
    "scenario": "language",
    "ro": "Vorbiți rusă?",
    "en": "Do you speak Russian?",
    "ru": "Вы говорите по-русски?",
    "note": "Useful in Moldova — Russian is widely understood."
  },
  {
    "id": "l03",
    "scenario": "language",
    "ro": "Nu vorbesc românește.",
    "en": "I don't speak Romanian.",
    "ru": "Я не говорю по-румынски."
  },
  {
    "id": "l04",
    "scenario": "language",
    "ro": "Vorbesc puțin.",
    "en": "I speak a little.",
    "ru": "Я говорю немного."
  },
  {
    "id": "l05",
    "scenario": "language",
    "ro": "Nu înțeleg.",
    "en": "I don't understand.",
    "ru": "Я не понимаю."
  },
  {
    "id": "l06",
    "scenario": "language",
    "ro": "Puteți să repetați, vă rog?",
    "en": "Can you repeat, please?",
    "ru": "Повторите, пожалуйста."
  },
  {
    "id": "l07",
    "scenario": "language",
    "ro": "Puteți să vorbiți mai rar?",
    "en": "Can you speak more slowly?",
    "ru": "Можете говорить медленнее?"
  },

  {
    "id": "c01",
    "scenario": "customs",
    "ro": "Sunt aici pentru turism.",
    "en": "I'm here for tourism.",
    "ru": "Я здесь как турист."
  },
  {
    "id": "c02",
    "scenario": "customs",
    "ro": "Stau o săptămână.",
    "en": "I'm staying one week.",
    "ru": "Я остаюсь на неделю.",
    "note": "Swap 'o săptămână' for 'două săptămâni' (two weeks) or 'zece zile' (ten days)."
  },
  {
    "id": "c03",
    "scenario": "customs",
    "ro": "Acesta este pașaportul meu.",
    "en": "This is my passport.",
    "ru": "Вот мой паспорт.",
    "note": "Definite article in Romanian is a SUFFIX: 'pașaport' → 'pașaportul' (the passport)."
  },
  {
    "id": "c04",
    "scenario": "customs",
    "ro": "Nu am nimic de declarat.",
    "en": "I have nothing to declare.",
    "ru": "Мне нечего декларировать."
  },
  {
    "id": "c05",
    "scenario": "customs",
    "ro": "Stau la un hotel.",
    "en": "I'm staying at a hotel.",
    "ru": "Я остановлюсь в отеле."
  },

  {
    "id": "s01",
    "scenario": "shop",
    "ro": "Cât costă?",
    "en": "How much does it cost?",
    "ru": "Сколько стоит?"
  },
  {
    "id": "s02",
    "scenario": "shop",
    "ro": "Aș dori asta, vă rog.",
    "en": "I would like this, please.",
    "ru": "Я бы хотел/а это, пожалуйста.",
    "note": "'Aș dori' is the polite conditional 'I would like' — softer than 'vreau' (I want)."
  },
  {
    "id": "s03",
    "scenario": "shop",
    "ro": "Aveți pâine?",
    "en": "Do you have bread?",
    "ru": "У вас есть хлеб?",
    "note": "Swap 'pâine' for any item: apă (water), lapte (milk), ouă (eggs)."
  },
  {
    "id": "s04",
    "scenario": "shop",
    "ro": "Unde este toaleta?",
    "en": "Where is the toilet?",
    "ru": "Где туалет?",
    "note": "Note the suffix: 'toaletă' (a toilet) → 'toaleta' (the toilet)."
  },
  {
    "id": "s05",
    "scenario": "shop",
    "ro": "Apă plată, vă rog.",
    "en": "Still water, please.",
    "ru": "Воду без газа, пожалуйста.",
    "note": "'Apă plată' = still water; 'apă minerală' = sparkling. Important — defaults vary."
  },
  {
    "id": "s06",
    "scenario": "shop",
    "ro": "O cafea, vă rog.",
    "en": "A coffee, please.",
    "ru": "Один кофе, пожалуйста.",
    "note": "'O' is the indefinite article for feminine nouns; 'un' for masculine. 'Cafea' is feminine."
  },
  {
    "id": "s07",
    "scenario": "shop",
    "ro": "Plătesc cu cardul.",
    "en": "I'll pay by card.",
    "ru": "Я плачу картой."
  },
  {
    "id": "s08",
    "scenario": "shop",
    "ro": "Plătesc cu numerar.",
    "en": "I'll pay in cash.",
    "ru": "Я плачу наличными.",
    "note": "Moldova: cash still common at markets, ATMs widely available in cities."
  },
  {
    "id": "s09",
    "scenario": "shop",
    "ro": "Bonul, vă rog.",
    "en": "The receipt, please.",
    "ru": "Чек, пожалуйста."
  },
  {
    "id": "s10",
    "scenario": "shop",
    "ro": "E prea scump.",
    "en": "It's too expensive.",
    "ru": "Это слишком дорого.",
    "note": "Useful at markets where bargaining is OK; not at fixed-price shops."
  },

  {
    "id": "r01",
    "scenario": "restaurant",
    "ro": "O masă pentru doi, vă rog.",
    "en": "A table for two, please.",
    "ru": "Столик на двоих, пожалуйста."
  },
  {
    "id": "r02",
    "scenario": "restaurant",
    "ro": "Meniul, vă rog.",
    "en": "The menu, please.",
    "ru": "Меню, пожалуйста."
  },
  {
    "id": "r03",
    "scenario": "restaurant",
    "ro": "Ce recomandați?",
    "en": "What do you recommend?",
    "ru": "Что вы рекомендуете?"
  },
  {
    "id": "r04",
    "scenario": "restaurant",
    "ro": "Este foarte bun.",
    "en": "It's very good.",
    "ru": "Очень вкусно."
  },
  {
    "id": "r05",
    "scenario": "restaurant",
    "ro": "Nota, vă rog.",
    "en": "The bill, please.",
    "ru": "Счёт, пожалуйста."
  },

  {
