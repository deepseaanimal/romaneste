    "scenario": "numbers",
    "ro": "doi",
    "en": "two (2)",
    "ru": "два",
    "note": "'Doi' is masculine. Feminine is 'două' — 'două cafele' (two coffees), 'două ape' (two waters). Gender of the noun determines which to use."
  },
  {
    "id": "num-3",
    "scenario": "numbers",
    "ro": "trei",
    "en": "three (3)",
    "ru": "три"
  },
  {
    "id": "num-4",
    "scenario": "numbers",
    "ro": "patru",
    "en": "four (4)",
    "ru": "четыре"
  },
  {
    "id": "num-5",
    "scenario": "numbers",
    "ro": "cinci",
    "en": "five (5)",
    "ru": "пять"
  },
  {
    "id": "num-6",
    "scenario": "numbers",
    "ro": "șase",
    "en": "six (6)",
    "ru": "шесть"
  },
  {
    "id": "num-7",
    "scenario": "numbers",
    "ro": "șapte",
    "en": "seven (7)",
    "ru": "семь"
  },
  {
    "id": "num-8",
    "scenario": "numbers",
    "ro": "opt",
    "en": "eight (8)",
    "ru": "восемь"
  },
  {
    "id": "num-9",
    "scenario": "numbers",
    "ro": "nouă",
    "en": "nine (9)",
    "ru": "девять",
    "note": "Same word as 'new' (feminine) — context decides which one is meant."
  },
  {
    "id": "num-10",
    "scenario": "numbers",
    "ro": "zece",
    "en": "ten (10)",
    "ru": "десять"
  },
  {
    "id": "num-11",
    "scenario": "numbers",
    "ro": "unsprezece",
    "en": "eleven (11)",
    "ru": "одиннадцать",
    "note": "Often shortened to 'unșpe' in fast speech. Same goes for 12-19 (doișpe, treișpe, etc.)."
  },
  {
    "id": "num-12",
    "scenario": "numbers",
    "ro": "doisprezece",
    "en": "twelve (12)",
    "ru": "двенадцать",
    "note": "Spoken: often 'doișpe'. Time: 'ora doisprezece' = twelve o'clock."
  },
  {
    "id": "num-15",
    "scenario": "numbers",
    "ro": "cincisprezece",
    "en": "fifteen (15)",
    "ru": "пятнадцать"
  },
  {
    "id": "num-20",
    "scenario": "numbers",
    "ro": "douăzeci",
    "en": "twenty (20)",
    "ru": "двадцать",
    "note": "Literally 'two tens'. From 20 upward, you need 'de' before a noun: 'douăzeci de lei' (20 lei)."
  },
  {
    "id": "num-30",
    "scenario": "numbers",
    "ro": "treizeci",
    "en": "thirty (30)",
    "ru": "тридцать"
  },
  {
    "id": "num-50",
    "scenario": "numbers",
    "ro": "cincizeci",
    "en": "fifty (50)",
    "ru": "пятьдесят"
  },
  {
    "id": "num-100",
    "scenario": "numbers",
    "ro": "o sută",
    "en": "one hundred (100)",
    "ru": "сто",
    "note": "Two hundred = 'două sute'. Five hundred = 'cinci sute'."
  },
  {
    "id": "num-500",
    "scenario": "numbers",
    "ro": "cinci sute",
    "en": "five hundred (500)",
    "ru": "пятьсот"
  },
  {
    "id": "num-1000",
    "scenario": "numbers",
    "ro": "o mie",
    "en": "one thousand (1000)",
    "ru": "тысяча",
    "note": "In Moldova, prices over 1000 lei are common for hotels/groceries-for-the-week. Two thousand = 'două mii'."
  },

  {
    "id": "p01",
    "scenario": "shop",
    "ro": "Costă zece lei.",
    "en": "It costs 10 lei.",
    "ru": "Стоит 10 леев.",
    "note": "Numbers 1-19 connect directly to the noun: 'zece lei', 'cinci lei'. No 'de' needed."
  },
  {
    "id": "p02",
    "scenario": "shop",
    "ro": "Costă douăzeci de lei.",
    "en": "It costs 20 lei.",
    "ru": "Стоит 20 леев.",
    "note": "Important rule: from 20 upward, insert 'de' before the noun. 'Cincizeci de lei' (50), 'o sută de lei' (100). Without 'de' it sounds wrong."
  },
  {
    "id": "p03",
    "scenario": "shop",
    "ro": "Costă o sută de lei.",
    "en": "It costs 100 lei.",
    "ru": "Стоит 100 леев."
  },
  {
    "id": "p04",
    "scenario": "shop",
    "ro": "Două cafele, vă rog.",
    "en": "Two coffees, please.",
    "ru": "Два кофе, пожалуйста.",
    "note": "Feminine 'două' because 'cafea' is feminine (plural 'cafele'). For masculine plurals use 'doi': 'doi pacienți' (two patients)."
  },
  {
    "id": "p05",
    "scenario": "shop",
    "ro": "Cinci kilograme, vă rog.",
    "en": "Five kilograms, please.",
    "ru": "Пять килограмм, пожалуйста."
  },
  {
    "id": "p06",
    "scenario": "shop",
    "ro": "Aveți rest?",
    "en": "Do you have change?",
    "ru": "У вас есть сдача?",
    "note": "When paying cash with a big bill. 'Rest' = change owed back to you."
  },

  {
    "id": "gr-dm",
    "scenario": "greetings",
    "ro": "Bună dimineața!",
    "en": "Good morning!",
    "ru": "Доброе утро!",
    "note": "Used until about midday. 'Dimineață' = morning."
  },
  {
    "id": "gr-bs",
    "scenario": "greetings",
    "ro": "Bună seara!",
    "en": "Good evening!",
    "ru": "Добрый вечер!",
    "note": "Used after ~6pm. 'Seară' = evening."
  },
  {
    "id": "gr-nb",
    "scenario": "greetings",
    "ro": "Noapte bună!",
    "en": "Good night!",
    "ru": "Спокойной ночи!"
  },
  {
    "id": "gr-pb",
    "scenario": "greetings",
    "ro": "Îmi pare bine!",
    "en": "Nice to meet you!",
    "ru": "Приятно познакомиться!",
    "note": "Literal: 'it seems good to me'. Said when meeting someone for the first time."
  },
  {
    "id": "gr-ik",
    "scenario": "greetings",
    "ro": "Încântată de cunoștință!",
    "en": "Pleased to meet you! (feminine speaker)",
    "ru": "Очень приятно!",
    "note": "'Încântată' is feminine. Men say 'Încântat'. You'd use 'Încântată' since you're a woman."
  },
  {
    "id": "gr-cn",
    "scenario": "greetings",
    "ro": "Cum te numești?",
    "en": "What's your name? (informal)",
    "ru": "Как тебя зовут?",
    "note": "Informal 'you'. Formal: 'Cum vă numiți?' Worth recognizing even if you won't ask it."
  },
  {
    "id": "gr-mn",
    "scenario": "greetings",
    "ro": "Mă numesc Diana.",
    "en": "My name is Diana.",
    "ru": "Меня зовут Диана.",
    "note": "Literally 'I call myself Diana'. More formal than 'Sunt Diana' (I am Diana)."
  },
  {
    "id": "gr-cmf",
    "scenario": "greetings",
    "ro": "Ce mai faci?",
    "en": "How are you? (casual, lit. 'what more are you doing?')",
    "ru": "Как дела?",
    "note": "Very common. Informal. The 'mai' softens it — not 'what are you doing' but a friendly check-in."
  },
  {
    "id": "gr-bst",
    "scenario": "greetings",
    "ro": "Bine, și tu?",
    "en": "Fine, and you?",
    "ru": "Хорошо, а ты?",
    "note": "Standard response to 'Ce mai faci?' Switch 'tu' to 'dumneavoastră' for formal: 'Bine, și dumneavoastră?'"
  },
  {
    "id": "gr-mf",
    "scenario": "greetings",
    "ro": "Mulțumesc frumos!",
    "en": "Thank you very much! (lit. 'thank you beautifully')",
    "ru": "Большое спасибо!"
  },
  {
    "id": "gr-pf",
    "scenario": "greetings",
    "ro": "Poftiți!",
    "en": "Here you are! / Please, go ahead! / Come in!",
    "ru": "Пожалуйста! / Прошу!",
    "note": "Very versatile. Said when handing something over, inviting someone in, or telling someone to go ahead. You'll hear this a lot."
  },
  {
    "id": "gr-pc",
    "scenario": "greetings",
    "ro": "Pe curând!",
    "en": "See you soon!",
    "ru": "До скорого!"
  },
  {
    "id": "gr-nv",
    "scenario": "greetings",
    "ro": "Ne vedem mai târziu!",
    "en": "See you later!",
    "ru": "До позже! / Увидимся позже!"
  },
  {
    "id": "gr-ozb",
    "scenario": "greetings",
    "ro": "O zi bună!",
    "en": "Have a nice day!",
    "ru": "Хорошего дня!",
    "note": "Very common farewell in shops and offices. The polite reply is 'Mulțumesc, și dumneavoastră!'"
  },
  {
    "id": "gr-osp",
    "scenario": "greetings",
    "ro": "O seară plăcută!",
    "en": "Have a nice evening!",
    "ru": "Приятного вечера!"
  },
  {
    "id": "gr-pa",
    "scenario": "greetings",
    "ro": "Pa!",
    "en": "Bye! (very casual)",
    "ru": "Пока!"
  },
  {
    "id": "gr-noroc",
    "scenario": "greetings",
    "ro": "Noroc!",
    "en": "Cheers! / Good luck!",
