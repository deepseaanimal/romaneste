    "en": "Help!",
    "ru": "Помогите!"
  },
  {
    "id": "h02",
    "scenario": "help",
    "ro": "Mă simt rău.",
    "en": "I feel ill.",
    "ru": "Мне плохо."
  },
  {
    "id": "h03",
    "scenario": "help",
    "ro": "Aveți nevoie de ajutor?",
    "en": "Do you need help?",
    "ru": "Вам нужна помощь?",
    "note": "Worth recognizing — someone may say this to you."
  },
  {
    "id": "h04",
    "scenario": "help",
    "ro": "Unde este farmacia?",
    "en": "Where is the pharmacy?",
    "ru": "Где аптека?"
  },
  {
    "id": "h05",
    "scenario": "help",
    "ro": "Sunați la poliție.",
    "en": "Call the police.",
    "ru": "Вызовите полицию."
  },

  {
