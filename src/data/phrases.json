  { "id": "bk01", "scenario": "bank", "ro": "Vreau să schimb bani.", "en": "I want to exchange money.", "ru": "Я хочу обменять деньги." },
  { "id": "bk02", "scenario": "bank", "ro": "Care este cursul de schimb?", "en": "What is the exchange rate?", "ru": "Какой курс обмена?", "note": "'Curs de schimb' = exchange rate. Ask this before exchanging — rates vary a lot between banks and exchange offices." },
  { "id": "bk03", "scenario": "bank", "ro": "Vreau să deschid un cont.", "en": "I want to open an account.", "ru": "Я хочу открыть счёт." },
  { "id": "bk04", "scenario": "bank", "ro": "Vreau să retrag bani.", "en": "I want to withdraw money.", "ru": "Я хочу снять деньги.", "note": "'A retrage' = to withdraw. ATM = 'bancomat'." },
  { "id": "bk05", "scenario": "bank", "ro": "Vreau să depun bani.", "en": "I want to deposit money.", "ru": "Я хочу положить деньги на счёт." },
  { "id": "bk06", "scenario": "bank", "ro": "Pot plăti cu cardul?", "en": "Can I pay by card?", "ru": "Могу ли я заплатить картой?", "note": "'Card' is used — same word as in English/Russian." },
  { "id": "bk07", "scenario": "bank", "ro": "Unde este bancomatul cel mai apropiat?", "en": "Where is the nearest ATM?", "ru": "Где ближайший банкомат?", "note": "'Bancomat' = ATM. 'Cel mai apropiat' = nearest." },
  { "id": "bk08", "scenario": "bank", "ro": "Care este comisionul?", "en": "What is the fee?", "ru": "Какая комиссия?" },
  { "id": "bk09", "scenario": "bank", "ro": "Vreau să fac un transfer.", "en": "I want to make a transfer.", "ru": "Я хочу сделать перевод." },
  { "id": "bk10", "scenario": "bank", "ro": "Câți lei primiți pe un dolar?", "en": "How many lei do you give per dollar?", "ru": "Сколько леев за доллар?", "note": "Direct way to ask the rate when exchanging USD. Swap 'dolar' for 'euro' as needed." },

  { "id": "doc01", "scenario": "documents", "ro": "Vreau să îmi reînnoiesc buletinul.", "en": "I want to renew my ID card.", "ru": "Я хочу продлить удостоверение личности.", "note": "'Buletin' = Moldovan national ID card. 'A reînnoi' = to renew." },
  { "id": "doc02", "scenario": "documents", "ro": "Ce acte am nevoie?", "en": "What documents do I need?", "ru": "Какие документы мне нужны?", "note": "'Acte' = documents/papers. Very useful at any government office." },
  { "id": "doc03", "scenario": "documents", "ro": "Unde este ghișeul?", "en": "Where is the counter/window?", "ru": "Где окошко (стойка)?", "note": "'Ghișeu' = service window at a bank, post office, or government office." },
  { "id": "doc04", "scenario": "documents", "ro": "Câte zile durează?", "en": "How many days does it take?", "ru": "Сколько дней это занимает?", "note": "'A dura' = to take (time). Can also say 'Cât durează?' = How long does it take?" },
  { "id": "doc05", "scenario": "documents", "ro": "Trebuie să completez un formular?", "en": "Do I need to fill out a form?", "ru": "Мне нужно заполнить анкету?", "note": "'Formular' = form. 'A completa' = to fill in/out." },
  { "id": "doc06", "scenario": "documents", "ro": "Am o programare la ora unsprezece.", "en": "I have an appointment at eleven o'clock.", "ru": "У меня запись на одиннадцать.", "note": "Swap the time as needed. 'Programare' = appointment/booking." },
  { "id": "doc07", "scenario": "documents", "ro": "Pot face o programare online?", "en": "Can I make an appointment online?", "ru": "Могу ли я записаться онлайн?" },
  { "id": "doc08", "scenario": "documents", "ro": "Pașaportul meu a expirat.", "en": "My passport has expired.", "ru": "Мой паспорт истёк.", "note": "'A expira' = to expire. Same for buletin: 'Buletinul meu a expirat.'" },
  { "id": "doc09", "scenario": "documents", "ro": "Unde este primăria?", "en": "Where is the city hall?", "ru": "Где мэрия?", "note": "'Primărie' = city hall / municipal office. Many document services go through here." },
  { "id": "doc10", "scenario": "documents", "ro": "Iată documentele mele.", "en": "Here are my documents.", "ru": "Вот мои документы.", "note": "'Iată' = here is / here are. Useful when handing papers to an official." },

  { "id": "cx01", "scenario": "complex", "ro": "Mulțumesc frumos pentru ajutor.", "en": "Thank you very much for your help.", "ru": "Большое спасибо за помощь.", "note": "'Frumos' (beautiful) added after 'mulțumesc' makes it warmer — like 'thank you kindly'." },
  { "id": "cx02", "scenario": "complex", "ro": "Nu am înțeles. Puteți repeta, vă rog?", "en": "I didn't understand. Can you repeat, please?", "ru": "Я не понял(а). Повторите, пожалуйста.", "note": "Combines 'nu înțeleg' (present) with perfect tense — 'nu am înțeles' = I didn't understand (just now)." },
  { "id": "cx03", "scenario": "complex", "ro": "Pot să vă pun o întrebare?", "en": "May I ask you a question?", "ru": "Могу я задать вам вопрос?", "note": "Polite way to open a conversation with a stranger or official." },
  { "id": "cx04", "scenario": "complex", "ro": "Îmi pare rău, am întârziat.", "en": "I'm sorry, I'm late.", "ru": "Извините, я опоздал(а).", "note": "'Îmi pare rău' = I'm sorry. 'A întârzia' = to be late." },
  { "id": "cx05", "scenario": "complex", "ro": "Unde pot găsi un loc să mănânc?", "en": "Where can I find a place to eat?", "ru": "Где я могу найти место поесть?", "note": "'A găsi' = to find. 'A mânca' = to eat. 'Loc' = place." },
  { "id": "cx06", "scenario": "complex", "ro": "Cât timp durează până la centru?", "en": "How long does it take to get to the center?", "ru": "Сколько времени до центра?", "note": "Building on time vocab. 'Centru' = city center. Swap for any destination." },
  { "id": "cx07", "scenario": "complex", "ro": "Vorbiți română sau rusă?", "en": "Do you speak Romanian or Russian?", "ru": "Вы говорите по-румынски или по-русски?", "note": "Moldova is bilingual. Useful opener — many people are more comfortable in Russian." }
